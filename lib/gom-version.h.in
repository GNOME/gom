#pragma once

#define GOM_MAJOR_VERSION (@MAJOR_VERSION@)
#define GOM_MINOR_VERSION (@MINOR_VERSION@)
#define GOM_MICRO_VERSION (@MICRO_VERSION@)
#define GOM_VERSION (@VERSION@)
#define GOM_VERSION_S "@VERSION@"
#define GOM_ENCODE_VERSION(major,minor,micro) \
  ((major) << 24 | (minor) << 16 | (micro) << 8)
#define GOM_VERSION_HEX \
  (GOM_ENCODE_VERSION (GOM_MAJOR_VERSION, GOM_MINOR_VERSION, GOM_MICRO_VERSION))
#define GOM_CHECK_VERSION(major,minor,micro)   \
  (GOM_MAJOR_VERSION > (major) || \
   (GOM_MAJOR_VERSION == (major) && GOM_MINOR_VERSION > (minor)) || \
   (GOM_MAJOR_VERSION == (major) && GOM_MINOR_VERSION == (minor) && \
    GOM_MICRO_VERSION >= (micro)))
