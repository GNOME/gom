[library]
version = "@version@"
browse_url = "https://gitlab.gnome.org/GNOME/gom/-/tree/main/"
repository_url = "https://gitlab.gnome.org/GNOME/gom"
website_url = "https://gitlab.gnome.org/GNOME/gom/"
docs_url = "https://gnome.pages.gitlab.gnome.org/gom/libgom-2/"
authors = "Christian Hergert"
license = "LGPL-2.1-or-later"
description = "Asynchronous data-mapper library for GObject-based applications with optional database backends."
dependencies = ["Gio-2.0", "Dex-1"]
devhelp = true
search_index = true

[dependencies."GObject-2.0"]
name = "GObject"
description = "The base type system library"
docs_url = "https://docs.gtk.org/gobject/"

[dependencies."GLib-2.0"]
name = "GLib"
description = "The base type system library"
docs_url = "https://docs.gtk.org/glib/"

[dependencies."Gio-2.0"]
name = "GIO"
description = "GObject Interfaces and Objects, Networking, IPC, and I/O"
docs_url = "https://docs.gtk.org/gio/"

[dependencies."Dex-1"]
name = "Dex"
description = "Future-based programming for GNOME"
docs_url = "https://gnome.pages.gitlab.gnome.org/libdex/"

[theme]
name = "basic"
show_index_summary = true
show_class_hierarchy = true

[source-location]
base_url = "https://gitlab.gnome.org/GNOME/gom/-/blob/main/"

[extra]
# The same order will be used when generating the index
content_files = [
  "overview.md",
  "quickstart.md",
  "migration-guide.md",
  "session.md",
  "relationships.md",
  "ui-models.md",
  "mutations-and-entity-crud.md",
  "migrations-and-versioning.md",
  "examples-entity-mapper.md",
  "examples-cursor-record.md",
  "examples-sqlite-encryption.md",
  "examples-python.md",
]

urlmap_file = "urlmap.js"
